APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Google Search Console (HTML tag verification — paste content only, not the full tag)
# GOOGLE_SITE_VERIFICATION=

# Storybook AI (set STORY_USE_FAKE_AI=true for local dev without OpenAI calls)
STORY_USE_FAKE_AI=true
OPENAI_API_KEY=
# OPENAI_ORGANIZATION=

# Runway video (required for real page videos when STORY_USE_FAKE_AI=false)
# RUNWAY_API_KEY=
# RUNWAY_API_VERSION=2024-11-06
# RUNWAY_MODEL=gen4_turbo
# RUNWAY_RATIO=1280:720
# RUNWAY_DURATION_SECONDS=10
# RUNWAY_MIN_DURATION_SECONDS=5
# RUNWAY_MAX_DURATION_SECONDS=10
# RUNWAY_POLL_INTERVAL_MS=2000
# RUNWAY_MAX_POLLS=120
# FFMPEG_BINARY=ffmpeg

# false = all story jobs use the "default" queue (plain `php artisan queue:work` is enough).
# true = use dedicated queues; run workers per STORY_QUEUE_* name.
STORY_DEDICATED_QUEUES=false

# If you previously queued jobs on story-* queues, run: php artisan story:queues-to-default
# STORY_QUEUE_TEXT=story-text
# STORY_QUEUE_IMAGE=story-image
# STORY_QUEUE_AUDIO=story-audio
# STORY_QUEUE_VIDEO=story-video

# Cloudinary (optional). Easiest: paste the full URL from Dashboard → API Keys → "API environment variable":
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# Or set CLOUDINARY_CLOUD_NAME, CLOUDINARY_API_KEY, CLOUDINARY_API_SECRET instead.
# Leave all empty to use storage/app/public + /storage URLs.
# CLOUDINARY_URL=
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# CLOUDINARY_FOLDER=ai-story-book
# CLOUDINARY_UPLOAD_PRESET=   # optional, for unsigned browser uploads only

PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_SANDBOX=true
STORY_ADMIN_EMAILS=you@example.com,admin2@example.com

# JVZoo IPN v2
JVZOO_SECRET=
JVZOO_PRODUCT_BASIC_ID=
JVZOO_PRODUCT_PRO_ID=
JVZOO_PRODUCT_ELITE_ID=
JVZOO_BASIC_CREDITS=30
JVZOO_PRO_CREDITS=150
JVZOO_ELITE_CREDITS=500